---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, localizedPath, formatDate } from '../../lib/i18n';
import { getPosts, postPath } from '../../lib/posts';
import type { Lang } from '../../config';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const posts = await getPosts(lang);

// Group by year, newest first.
const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const y = post.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---
<BaseLayout title={t('archive.title')}>
  <h1 class="page-title">{t('archive.title')}</h1>
  {
    years.map((year) => (
      <section class="archive-year">
        <h2>{year}</h2>
        <ul class="archive-list">
          {byYear.get(year)!.map((post) => (
            <li>
              <time datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date, lang)}
              </time>
              <a href={postPath(post)}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</BaseLayout>
