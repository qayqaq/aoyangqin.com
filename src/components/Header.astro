---
import { SITE, NAV } from '../config';
import { getLangFromUrl, useTranslations, localizedPath, swapLocalePath } from '../lib/i18n';
import ThemeToggle from './ThemeToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const otherLang = lang === 'en' ? 'zh' : 'en';
const otherPath = swapLocalePath(Astro.url.pathname, otherLang);
const homeHref = localizedPath('/', lang);
---

<header class="site-header">
  <div class="header-inner">
    <a class="site-title" href={homeHref}>{SITE.title}</a>

    <nav class="site-nav">
      {
        NAV.map((item) => (
          <a href={localizedPath(item.href, lang)}>{t(item.key)}</a>
        ))
      }
    </nav>

    <div class="header-actions">
      <button
        id="search-trigger"
        class="icon-btn"
        aria-label={t('search')}
        title={`${t('search')} (Ctrl/⌘ K)`}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>

      <a class="lang-switch" href={otherPath} aria-label="Switch language">
        {otherLang === 'zh' ? '中' : 'EN'}
      </a>

      <ThemeToggle />
    </div>
  </div>
</header>

<!-- Pagefind search modal -->
<div id="search-modal" class="search-modal" hidden>
  <div class="search-backdrop" data-close></div>
  <div class="search-box">
    <div id="search-ui"></div>
  </div>
</div>

<script>
  import { initSearch } from '../lib/search-ui';
  initSearch();
</script>
