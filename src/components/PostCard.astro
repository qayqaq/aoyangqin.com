---
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, localizedPath, formatDate } from '../lib/i18n';
import { postUrl } from '../lib/posts';

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const url = postUrl(post);
---
<article class="post-card">
  <div class="post-card-meta">
    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date, lang)}</time>
    {post.data.category && <span class="post-card-cat">{post.data.category}</span>}
  </div>
  <h2 class="post-card-title"><a href={url}>{post.data.title}</a></h2>
  {post.data.summary && <p class="post-card-summary">{post.data.summary}</p>}
  {post.data.tags?.length > 0 && (
    <div class="post-card-tags">
      {post.data.tags.map((tag) => (
        <a class="tag" href={localizedPath(`/tags/${tag}`, lang)}>#{tag}</a>
      ))}
    </div>
  )}
</article>
